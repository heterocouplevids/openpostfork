{
  "name": "openpost",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "sync:assets": "node scripts/sync-assets.mjs",
    "sync:docs-external": "node scripts/sync-docs-external.mjs",
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "check": "turbo run check",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "docs:dev": "pnpm run sync:assets && pnpm run sync:docs-external && pnpm --filter @openpost/docs docs:dev",
    "docs:build": "pnpm run sync:assets && pnpm run sync:docs-external && pnpm --filter @openpost/docs docs:build",
    "docs:preview": "pnpm --filter @openpost/docs docs:preview",
    "frontend:dev": "pnpm --filter @openpost/web dev",
    "frontend:build": "pnpm --filter @openpost/web build",
    "marketing:dev": "pnpm run sync:assets && pnpm --filter @openpost/site dev",
    "marketing:build": "pnpm run sync:assets && pnpm --filter @openpost/site build",
    "marketing:preview": "pnpm --filter @openpost/site preview"
  },
  "devDependencies": {
    "turbo": "^2.6.3"
  }
}
