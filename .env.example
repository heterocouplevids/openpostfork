# OpenPost Configuration
# =============================================================================
# IMPORTANT: Set OPENPOST_APP_URL to the URL the SPA is served from. Most
# other settings (OAuth callback URLs, WebAuthn RPID, CORS) are derived
# from it automatically. The example values below are Vite's dev port so
# `bun run dev` works out of the box — replace them before deploying.
# =============================================================================

# =============================================================================
# Server Configuration
# =============================================================================
OPENPOST_PORT=8080
OPENPOST_DATABASE_PATH=file:openpost.db?cache=shared&mode=rwc
OPENPOST_MEDIA_PATH=./media
OPENPOST_MEDIA_URL=/media
# The URL the browser uses to reach the OpenPost UI. Used to derive OAuth
# callback URLs, the WebAuthn RPID, and CORS. No trailing slash.
OPENPOST_APP_URL=http://localhost:5173
# Public-facing URL (for email links, WebAuthn origins, etc.). Falls back
# to OPENPOST_APP_URL if unset.
OPENPOST_PUBLIC_URL=http://localhost:5173
OPENPOST_EXTRA_CORS_ORIGINS=
OPENPOST_DISABLE_REGISTRATIONS=false
TZ=UTC

# =============================================================================
# Authentication Secrets (GENERATE NEW ONES FOR PRODUCTION)
# =============================================================================
# Generate with: openssl rand -base64 32
OPENPOST_JWT_SECRET=change-this-jwt-secret-min-32-chars
OPENPOST_ENCRYPTION_KEY=change-this-encryption-key-32ch

# =============================================================================
# Platform OAuth Credentials
# =============================================================================
# Configure only the platforms you need. Leave empty to disable a platform.
# Each *_REDIRECT_URI below is OPTIONAL — if you leave it blank, OpenPost
# derives the correct value from OPENPOST_APP_URL. Only set it explicitly
# when your callback URL is different (e.g. behind a proxy or on a path).

# -----------------------------------------------------------------------------
# X/Twitter OAuth
# Get credentials from: https://developer.twitter.com/en/portal/dashboard
# Default redirect: ${OPENPOST_APP_URL}/api/v1/accounts/x/callback
# Required scopes: tweet.read, tweet.write, users.read, offline.access
# -----------------------------------------------------------------------------
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=

# -----------------------------------------------------------------------------
# Mastodon OAuth (supports multiple instances)
# Create an app on each instance: Settings > Development > New Application
# Required scopes: read, write
#
# MASTODON_REDIRECT_URI is special: it uses the OOB flow by default (the
# 'urn:ietf:wg:oauth:2.0:oob' scheme), which doesn't need a real callback
# URL. Only override this if you have a custom callback set up.
# -----------------------------------------------------------------------------
MASTODON_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob
MASTODON_SERVERS=[]

# -----------------------------------------------------------------------------
# Bluesky (App Passwords)
# No setup needed - just use your handle and app password from Bluesky settings.
# Settings > App Passwords > Create App Password
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# LinkedIn OAuth
# Get credentials from: https://www.linkedin.com/developers/apps
# Default redirect: ${OPENPOST_APP_URL}/api/v1/accounts/linkedin/callback
# Required scopes: openid, profile, w_member_social
# -----------------------------------------------------------------------------
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=
LINKEDIN_DISABLE_THREAD_REPLIES=false

# -----------------------------------------------------------------------------
# Threads OAuth (Meta Graph API)
# Get credentials from: https://developers.facebook.com/
# Create a Business app and add Threads API product
# Default redirect: ${OPENPOST_APP_URL}/api/v1/accounts/threads/callback
# Required scopes: threads_basic, threads_content_publish
#
# IMPORTANT: Threads requires HTTPS for OAuth redirects!
# For local development, use ngrok: ngrok http 5173
# -----------------------------------------------------------------------------
THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=
THREADS_REDIRECT_URI=
